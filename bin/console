#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use App\Attributes\Route;
use ReflectionClass;

echo "Discovered Routes:\n";
echo str_repeat("-", 50) . "\n";
echo sprintf("%-10s | %-25s | %s\n", "Method", "Path", "Controller::Action");
echo str_repeat("-", 50) . "\n";

$controllersPath = __DIR__ . '/../src/Controllers';
$iterator = new \RecursiveIteratorIterator(new \RecursiveDirectoryIterator($controllersPath));
$files = new \RegexIterator($iterator, '/\.php$/');

foreach ($files as $file) {
    $content = file_get_contents($file->getPathname());
    if (preg_match('/namespace\s+(.+?);/', $content, $namespaceMatches) &&
        preg_match('/class\s+(.+?)\s+/', $content, $classMatches)) {
        
        $className = $namespaceMatches[1] . '\\' . $classMatches[1];
        if (!class_exists($className)) continue;

        $reflection = new ReflectionClass($className);
        foreach ($reflection->getMethods() as $method) {
            $attributes = $method->getAttributes(Route::class);
            foreach ($attributes as $attribute) {
                $routeAttr = $attribute->newInstance();
                echo sprintf("%-10s | %-25s | %s::%s\n", 
                    $routeAttr->method, 
                    $routeAttr->path, 
                    $classMatches[1], 
                    $method->getName()
                );
            }
        }
    }
}
echo str_repeat("-", 50) . "\n";
