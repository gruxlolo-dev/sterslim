#!/usr/bin/env php
<?php

if ($argc < 3) {
    echo "Usage: bin/make [controller|service|middleware|module] [Name]\n";
    exit(1);
}

$type = strtolower($argv[1]);
$name = ucfirst($argv[2]);
$lowerName = strtolower($name);

function create_file($path, $content) {
    $dir = dirname($path);
    if (!is_dir($dir)) mkdir($dir, 0755, true);
    file_put_contents($path, $content);
    echo "CREATED: $path\n";
}

$templates = [
    'controller' => "<?php

namespace App\Controllers;

use App\Attributes\Route;
use App\Services\\{$name}Service;
use Psr\Http\Message\ResponseInterface as Response;
use Psr\Http\Message\ServerRequestInterface as Request;

class {$name}Controller
{
    private {$name}Service \$service;

    public function __construct()
    {
        \$this->service = new {$name}Service();
    }

    #[Route(path: \"/api/{$lowerName}\", method: \"GET\")]
    public function index(Request \$request, Response \$response): Response
    {
        \$data = \$this->service->all();
        
        \$response->getBody()->write(json_encode([
            'status' => 'success',
            'message' => '{$name} list retrieved',
            'data' => \$data
        ]));

        return \$response->withHeader('Content-Type', 'application/json');
    }

    #[Route(path: \"/api/{$lowerName}\", method: \"POST\")]
    public function store(Request \$request, Response \$response): Response
    {
        \$input = \$request->getParsedBody();
        \$result = \$this->service->create(\$input);

        \$response->getBody()->write(json_encode([
            'status' => 'success',
            'message' => '{$name} created successfully',
            'data' => \$result
        ]));

        return \$response->withHeader('Content-Type', 'application/json')->withStatus(201);
    }
}
",
    'service' => "<?php

namespace App\Services;

class {$name}Service
{
    public function all(): array
    {
        return [
            ['id' => 1, 'name' => 'Sample {$name} 1'],
            ['id' => 2, 'name' => 'Sample {$name} 2']
        ];
    }

    public function create(?array \$data): array
    {
        // Add business logic here
        return array_merge(['id' => rand(3, 100)], \$data ?? []);
    }
}
",
    'middleware' => "<?php

namespace App\Middlewares;

use Psr\Http\Message\ServerRequestInterface as Request;
use Psr\Http\Server\RequestHandlerInterface as Handler;
use Psr\Http\Message\ResponseInterface as Response;
use Slim\Psr7\Response as SlimResponse;

class {$name}Middleware
{
    public function __invoke(Request \$request, Handler \$handler): Response
    {
        // Example: API Key or Content-Type Check
        if (!\$request->hasHeader('Content-Type') && \$request->getMethod() === 'POST') {
            \$response = new SlimResponse();
            \$response->getBody()->write(json_encode(['error' => 'Content-Type header is required']));
            return \$response->withHeader('Content-Type', 'application/json')->withStatus(400);
        }

        return \$handler->handle(\$request);
    }
}
"
];

if ($type === 'module') {
    create_file("src/Controllers/{$name}Controller.php", $templates['controller']);
    create_file("src/Services/{$name}Service.php", $templates['service']);
    create_file("src/Middlewares/{$name}Middleware.php", $templates['middleware']);
} elseif (isset($templates[$type])) {
    $fileName = ($type === 'controller') ? "{$name}Controller.php" : (($type === 'service') ? "{$name}Service.php" : "{$name}Middleware.php");
    $folder = ($type === 'controller') ? "Controllers" : (($type === 'service') ? "Services" : "Middlewares");
    create_file("src/{$folder}/{$fileName}", $templates[$type]);
} else {
    echo "Unknown type: $type\n";
}
